# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="SSO Identity Provider"
APP_ENV=development
DEBUG=true
SECRET_KEY=change_me_to_a_long_random_string_at_least_64_chars
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8001

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=postgres
# Remote PostgreSQL (note the postgresql+asyncpg:// scheme — required for async SQLAlchemy)
# For local dev with docker-compose: postgresql+asyncpg://sso:sso_secret@db:5432/sso_db
DATABASE_URL=postgresql+asyncpg://postgres:hqg0WKNcFAM3G7kk10SHqHb6UNUqCI7CkeOahy40QVWO9hxop9aNB8Cp8DSfwZs5@72.61.174.129:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / OIDC ────────────────────────────────────────────────────────────────
# RSA keys are auto-generated on first run; set paths to persist them.
PRIVATE_KEY_PATH=keys/private.pem
PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ID_TOKEN_EXPIRE_MINUTES=60
AUTH_CODE_EXPIRE_MINUTES=10

# ── OIDC Issuer ──────────────────────────────────────────────────────────────
OIDC_ISSUER=http://localhost:8000

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sso.local
SMTP_TLS=false

# ── Social: Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Social: GitHub ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# ── Social: Microsoft ────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# ── Social: LinkedIn ─────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_PASSWORD_RESET=3/minute

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_EXPIRE_DAYS=7
SECURE_COOKIES=

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
SECRET_KEY=SrCfhhJyIb-s2BcWTYFe2-PaW6ZHFFVU_xt9dVuctDySF-vn_soKWXFI78hQ543zT7ZFf-TdAFaQHhrKPh565g